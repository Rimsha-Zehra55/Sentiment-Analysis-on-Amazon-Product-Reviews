    "print(\" LOADING DATA\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "def load_amazon_data_simple(file_path, num_samples=10000):\n",
    "    \"\"\"Simple and reliable loading function\"\"\"\n",
    "    print(f\"Loading {num_samples:,} reviews from {file_path}...\")\n",
    "    \n",
    "    data = []\n",
    "    count = 0\n",
    "    \n",
    "    with open(file_path, 'r', encoding='utf-8') as f:\n",
    "        for line in tqdm(f, total=num_samples, desc=\"Reading\"):\n",
    "            if count >= num_samples:\n",
    "                break\n",
    "                \n",
    "            # Remove whitespace\n",
    "            line = line.strip()\n",
    "            \n",
    "            if not line:  # Skip empty lines\n",
    "                continue\n",
    "                \n",
    "            # Split by first tab\n",
    "            if '\\t' in line:\n",
    "                parts = line.split('\\t', 1)\n",
    "            else:\n",
    "                # If no tab, split by first space\n",
    "                parts = line.split(' ', 1)\n",
    "            \n",
    "            if len(parts) == 2:\n",
    "                label, text = parts\n",
    "                \n",
    "                # Convert label to 0 or 1\n",
    "                if '__label__1' in label:\n",
    "                    sentiment = 0  # Negative\n",
    "                elif '__label__2' in label:\n",
    "                    sentiment = 1  # Positive\n",
    "                else:\n",
    "                    # If label is just '1' or '2'\n",
    "                    if '1' in label:\n",
    "                        sentiment = 0\n",
    "                    elif '2' in label:\n",
    "                        sentiment = 1\n",
    "                    else:\n",
    "                        continue  # Skip unknown format\n",
    "                \n",
    "                data.append([sentiment, text])\n",
    "                count += 1\n",
    "    \n",
    "    print(f\"\\n Loaded {len(data):,} reviews\")\n",
    "    return pd.DataFrame(data, columns=['sentiment', 'text'])\n",
    "\n",
    "# Load 10,000 reviews to start (you can increase later)\n",
    "df_train = load_amazon_data_simple('train.ft.txt', num_samples=10000)\n",
    "\n",
    "# If loading fails, create sample data\n",
    "if len(df_train) == 0:\n",
    "    print(\"\\n Could not load from file. Creating sample data...\")\n",
    "    \n",
    "    # Create sample dataset\n",
    "    np.random.seed(42)\n",
    "    n_samples = 10000\n",
    "    \n",
    "    positive_samples = [\n",
    "        \"I absolutely love this product! The quality is amazing and it works perfectly.\",\n",
    "        \"Excellent service and fast delivery. Will definitely buy again!\",\n",
    "        \"Best purchase I've ever made. Worth every penny!\",\n",
    "        \"Outstanding performance and great value for money.\",\n",
    "        \"Very satisfied with my purchase. Exceeds expectations!\"\n",
    "    ]\n",
    "    \n",
    "    negative_samples = [\n",
    "        \"Terrible product! Broke after one week. Waste of money.\",\n",
    "        \"Very disappointed with the quality. Not worth it.\",\n",
    "        \"Poor customer service and defective product.\",\n",
    "        \"Worst purchase ever. Save your money!\",\n",
    "        \"Does not work as advertised. Complete failure.\"\n",
    "    ]\n",
    "    \n",
    "    data = []\n",
    "    for i in range(n_samples):\n",
    "        if np.random.random() > 0.5: \n",
    "            text = np.random.choice(positive_samples)\n",
    "            sentiment = 1\n",
    "        else:  # 50% negative\n",
    "            text = np.random.choice(negative_samples)\n",
    "            sentiment = 0\n",
    "        data.append([sentiment, text])\n",
    "    \n",
    "    df_train = pd.DataFrame(data, columns=['sentiment', 'text'])\n",
    "    print(f\" Created sample dataset with {len(df_train):,} reviews\")\n",
    "\n",
    "print(f\"\\n Dataset loaded successfully!\")\n",
    "print(f\"Shape: {df_train.shape}\")\n",
    "print(f\"\\nFirst 3 rows:\")\n",
    "print(df_train.head(3))"
   ]
  },
